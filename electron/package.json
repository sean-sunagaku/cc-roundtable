{
  "name": "meeting-room-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Meeting Room desktop app for Agent Teams",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:daemon\" \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:daemon": "esbuild ../services/meeting-room-daemon/src/index.ts --bundle --platform=node --format=cjs --external:node-pty --outdir=../services/meeting-room-daemon/dist --sourcemap --watch --tsconfig=../services/meeting-room-daemon/tsconfig.json",
    "dev:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --external:node-pty --outdir=dist/main --sourcemap --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js file:dist/main/preload.js file:../services/meeting-room-daemon/dist/index.js && nodemon --watch dist/main/index.js --watch dist/main/preload.js --delay 200ms --signal SIGTERM --exec \"env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 electron . --remote-debugging-port=9222\"",
    "build": "npm run build:daemon && npm run build:main && npm run build:renderer",
    "build:daemon": "esbuild ../services/meeting-room-daemon/src/index.ts --bundle --platform=node --format=cjs --external:node-pty --outdir=../services/meeting-room-daemon/dist --sourcemap --tsconfig=../services/meeting-room-daemon/tsconfig.json",
    "build:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --external:node-pty --outdir=dist/main --sourcemap",
    "build:renderer": "vite build",
    "typecheck": "tsc -p ../services/meeting-room-daemon/tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "e2e:gui": "node ../e2e/gui/final-verification.mjs",
    "verify:final": "npm run typecheck && npm run build && npm run e2e:gui",
    "architecture": "node ../scripts/generate-architecture.mjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "marked": "^15.0.7",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@hhhtj/draw.io": "^14.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.5",
    "esbuild": "^0.25.9",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "wait-on": "^8.0.5"
  }
}
