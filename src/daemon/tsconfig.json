{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "typeRoots": ["../apps/desktop/node_modules/@types"],
    "baseUrl": "../..",
    "paths": {
      "@contracts/*": ["src/packages/shared-contracts/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../packages/shared-contracts/src/**/*.ts"]
}
