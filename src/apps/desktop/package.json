{
  "name": "meeting-room-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Meeting Room desktop app for Agent Teams",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:daemon\" \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:daemon": "esbuild ../../daemon/src/index.ts --bundle --platform=node --format=cjs --external:node-pty --outdir=../../daemon/dist --sourcemap --watch --tsconfig=../../daemon/tsconfig.json",
    "lint": "node ../../../scripts/run-eslint.mjs",
    "lint:fix": "node ../../../scripts/run-eslint.mjs --fix",
    "format": "prettier --write --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore ../../../",
    "format:check": "prettier --check --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore ../../../",
    "build:web": "node ../../../scripts/build-web-client.mjs",
    "build:web:watch": "node ../../../scripts/build-web-client.mjs --watch",
    "daemon:start": "node ../../../scripts/start-daemon.mjs",
    "daemon:start:dev": "node ../../../scripts/start-daemon.mjs --watch",
    "public-share:start": "node ../../../scripts/start-public-share-demo.mjs",
    "public-share:start:dev": "node ../../../scripts/start-public-share-demo.mjs --watch",
    "public-share:start:ngrok": "node ../../../scripts/start-public-share-demo.mjs --ngrok",
    "public-share:start:ngrok:dev": "node ../../../scripts/start-public-share-demo.mjs --watch --ngrok",
    "dev:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --external:node-pty --outdir=dist/main --sourcemap --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js file:dist/main/preload.js file:../../daemon/dist/index.js && nodemon --watch dist/main/index.js --watch dist/main/preload.js --delay 200ms --signal SIGTERM --exec \"env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 electron . --remote-debugging-port=9222\"",
    "build": "npm run build:web && npm run build:daemon && npm run build:main && npm run build:renderer",
    "build:daemon": "esbuild ../../daemon/src/index.ts --bundle --platform=node --format=cjs --external:node-pty --outdir=../../daemon/dist --sourcemap --tsconfig=../../daemon/tsconfig.json",
    "build:main": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --external:node-pty --outdir=dist/main --sourcemap",
    "build:renderer": "vite build",
    "typecheck": "tsc -p ../../daemon/tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit && tsc -p ../web/tsconfig.json --noEmit",
    "e2e:gui": "node ../../../e2e/gui/final-verification.mjs",
    "e2e:web": "node ../../../e2e/web/final-verification.mjs",
    "smoke:public-share": "node ../../../scripts/public-share-smoke.mjs",
    "smoke:runtime:real": "node ../../../scripts/real-runtime-smoke.mjs",
    "verify:final": "npm run lint && npm run format:check && npm run typecheck && npm run build && npm run e2e:gui",
    "architecture": "node ../../../scripts/generate-architecture.mjs",
    "architecture:new": "node ../../../scripts/scaffold-architecture-definition.mjs",
    "architecture:update-docs": "node ../../../scripts/update-architecture-definitions.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "hono": "^4.12.7",
    "lucide-react": "^0.577.0",
    "marked": "^15.0.7",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hhhtj/draw.io": "^14.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.2.5",
    "esbuild": "^0.25.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.4",
    "wait-on": "^8.0.5"
  }
}
