        <mxCell id="human" value="Human User&#xa;InputBar から発言" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#d68910;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="app" value="App.tsx&#xa;handleSend()&#xa;optimistic に pending human message を積む" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="330" y="110" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="sendHuman" value="meetingRoom.sendHumanMessage(meetingId, message)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="650" y="125" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="submitPrompt" value="MeetingService.sendHumanMessage()&#xa;『必ず team 全体へ broadcast してください』を前置して submitPrompt()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="970" y="110" width="270" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="ptyWrite" value="PtyManager.write(content) + write(\r)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="1320" y="125" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="claude2" value="Claude CLI / Agent Teams&#xa;leader が broadcast で全体共有しながら進行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="preHook" value="PreToolUse: enforce-broadcast.py&#xa;leader の directed message は reject" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="280" y="305" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="postHook1" value="PostToolUse: ws-relay.py&#xa;agent_message を JSON payload 化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="980" y="295" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="postHook2" value="PostToolUse: subagent-status-relay.py&#xa;agent_status(completed) を送信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="980" y="385" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="relay" value="RelayServer&#xa;WebSocketServer :9999&#xa;extractMarkedContent() で必要部分を抽出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
