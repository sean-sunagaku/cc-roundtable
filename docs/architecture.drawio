        <mxCell id="c1225" value="&lt;b&gt;Behavioral Psychologist&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;behavioral-psychologist&lt;/font&gt;&lt;br/&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;行動心理と習慣化の視点で継続可能な改善策を出す&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6baed6;strokeColor=#3182bd;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="600" width="220" height="75" as="geometry"/></mxCell>
