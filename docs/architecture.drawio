        <mxCell id="c1200" value="Meeting Lifecycle &amp;amp; State Machine" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="10" width="420" height="35" as="geometry"/></mxCell>
        <mxCell id="c1201" value="&lt;b&gt;1. Setup&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SetupScreen で設定&lt;br/&gt;• スキル選択&lt;br/&gt;• 議題入力&lt;br/&gt;• プロジェクトDir&lt;br/&gt;• メンバー選択&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebf7;strokeColor=#3182bd;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="240" height="120" as="geometry"/></mxCell>
        <mxCell id="c1202" value="&lt;b&gt;2. Start Meeting&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MeetingService.startMeeting()&lt;br/&gt;• .active flag 作成&lt;br/&gt;• PTY 起動 (zsh)&lt;br/&gt;• claude CLI 実行&lt;br/&gt;• 初期プロンプト送信&lt;br/&gt;  (/{skill} {topic})&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="300" y="80" width="240" height="140" as="geometry"/></mxCell>
        <mxCell id="c1203" value="&lt;b&gt;3. Running&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;会議進行中&lt;br/&gt;• Agent 間 broadcast&lt;br/&gt;• Human → InputBar → PTY&lt;br/&gt;• Hook → WS → ChatView&lt;br/&gt;• SubagentStop → status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="80" width="240" height="120" as="geometry"/></mxCell>
        <mxCell id="c1204" value="&lt;b&gt;4. Control&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;会議中操作&lt;br/&gt;• pause: 要点まとめ&lt;br/&gt;• resume: 再開&lt;br/&gt;• settings: 設定変更&lt;br/&gt;• retryMcp: MCP 復旧&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebf7;strokeColor=#3182bd;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="80" width="240" height="120" as="geometry"/></mxCell>
        <mxCell id="c1205" value="&lt;b&gt;5. End Meeting&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;MeetingService.endMeeting()&lt;br/&gt;• サマリー保存(.md)&lt;br/&gt;• PTY kill&lt;br/&gt;• .active flag 削除&lt;br/&gt;• タブ削除&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1080" y="80" width="240" height="120" as="geometry"/></mxCell>
